# ─────────────────────────────────────────────
#  USMS Server — Environment Variables
#  Copy to .env and fill in your values
#  Never commit .env to version control
# ─────────────────────────────────────────────

# ── App ───────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────
MONGO_URI=mongodb://localhost:27017/usms

# ── JWT ───────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ── Email / Brevo ─────────────────────────────
# Get API key: https://app.brevo.com → Settings → API Keys → Generate
# Sender must be a verified domain or email in your Brevo account
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_NAME=USMS
EMAIL_FROM_ADDRESS=no-reply@yourdomain.com

# ── Client ────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── File Uploads ──────────────────────────────
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880           # 5 MB in bytes
