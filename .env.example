# ─────────────────────────────────────────────
#  USMS Server — Environment Variables
#  Copy to .env and fill in your values
#  Never commit .env to version control
# ─────────────────────────────────────────────

# ── App ───────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────
MONGO_URI=mongodb://localhost:27017/usms

# ── JWT ───────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ── Email / SMTP ──────────────────────────────
# Gmail: enable 2FA → https://myaccount.google.com/apppasswords → create App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false               # set true only if using port 465
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx   # 16-char Gmail App Password (not your login password)
EMAIL_FROM="USMS" <your_gmail@gmail.com>

# ── Client ────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── File Uploads ──────────────────────────────
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880           # 5 MB in bytes
